<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>DEX-Monitor — Solana</title>
<style>
  :root { --bg:#0e1116; --card:#171c24; --line:#262d38; --txt:#e6edf3; --dim:#8b949e;
          --green:#3fb950; --red:#f85149; --gold:#d4a017; --blue:#58a6ff; --yellow:#d29922; }
  * { box-sizing:border-box; }
  body { margin:0; background:var(--bg); color:var(--txt);
         font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif; }
  header { padding:16px 22px; border-bottom:1px solid var(--line); display:flex;
           align-items:baseline; gap:14px; flex-wrap:wrap; }
  h1 { font-size:20px; margin:0; }
  h2 { font-size:14px; margin:0 0 10px; color:var(--dim); text-transform:uppercase;
       letter-spacing:.5px; font-weight:600; }
  .sub { color:var(--dim); font-size:13px; }
  #updated { color:var(--dim); font-size:12px; margin-left:auto; }
  section { padding:16px 22px; border-bottom:1px solid var(--line); }
  .cards { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:14px; }
  .kpi { background:var(--card); border:1px solid var(--line); border-radius:8px;
         padding:10px 16px; min-width:110px; }
  .kpi .v { font-size:20px; font-weight:600; font-variant-numeric:tabular-nums; }
  .kpi .l { font-size:11px; color:var(--dim); text-transform:uppercase; letter-spacing:.4px; }
  .note { color:var(--dim); font-size:12px; margin-top:4px; }
  .wrap { overflow-x:auto; }
  table { width:100%; border-collapse:collapse; font-size:13px; }
  th { text-align:left; color:var(--dim); font-weight:500; font-size:11px;
       text-transform:uppercase; letter-spacing:.5px; padding:7px 10px;
       border-bottom:1px solid var(--line); }
  td { padding:8px 10px; border-bottom:1px solid var(--line); font-variant-numeric:tabular-nums; }
  tr:hover td { background:#1b212b; }
  .sym { color:var(--blue); font-weight:600; }
  .pos { color:var(--green); } .neg { color:var(--red); } .dim { color:var(--dim); }
  .amber { color:var(--yellow); }
  .pill { padding:2px 8px; border-radius:10px; font-size:11px; }
  .pill.ok { background:rgba(63,185,80,.15); color:var(--green); }
  .pill.warn { background:rgba(210,153,34,.15); color:var(--yellow); }
  .pill.run { background:rgba(88,166,255,.15); color:var(--blue); }
  .pill.house { background:rgba(212,160,23,.15); color:var(--gold); }
  .pill.premium { background:rgba(212,160,23,.2); color:var(--gold); }
  .empty { color:var(--dim); padding:18px; text-align:center; font-style:italic; font-size:13px; }
  .premium-row td { border-left:3px solid var(--gold); background:rgba(212,160,23,0.04); }
  .premium-row:hover td { background:rgba(212,160,23,0.10); }
  .num { color:var(--dim); font-size:11px; text-align:right; padding-right:6px; }
  .two { display:grid; grid-template-columns:1fr 1fr; gap:26px; }
  @media (max-width:840px){ .two { grid-template-columns:1fr; } }
</style>
</head>
<body>
<header>
  <h1>🛰️ DEX-Monitor</h1>
  <span class="sub">Solana · Screening + Paper-Moonshot · kein echtes Geld</span>
  <div id="updated">lädt…</div>
</header>

<!-- ─────────── PAPER-MOONSHOT ─────────── -->
<section>
  <h2>🚀 Paper-Moonshot <span style="color:var(--dim);font-weight:400;text-transform:none;letter-spacing:0">— realistisch: 5% Slippage/Seite · ehrliche Rug-Verluste</span></h2>
  <div class="wrap" style="margin-bottom:14px"><table>
    <thead><tr><th>A/B-Vergleich (Start $500)</th><th class="num">Equity</th><th class="num">Rendite</th><th class="num">Trades</th><th class="num">WR</th><th class="num">NET</th><th class="num">Ø/Trade</th></tr></thead>
    <tbody id="abrows"></tbody>
  </table></div>
  <div style="color:var(--dim);font-size:12px;margin:-6px 0 14px">v9 = Fade-Cut · v10 = Velocity≤300 · v11 = beides · v12 = v11 mit echten Jupiter-Quotes (statt 5%-Pauschale) · Tabellen unten = v7 Kontrolle</div>
  <div class="cards" id="pcards"></div>
  <div class="two">
    <div>
      <h2>Offene Wetten</h2>
      <div class="wrap"><table>
        <thead><tr><th class="num">#</th><th>Symbol</th><th>Entry</th><th>Aktuell</th><th>P&L %</th><th>P&L $</th><th>Peak</th><th>Status</th></tr></thead>
        <tbody id="popen"></tbody>
      </table></div>
      <div class="empty" id="popen_e" style="display:none">Keine offenen Wetten — wartet auf Momentum-Token…</div>
    </div>
    <div>
      <h2>Letzte Trades</h2>
      <div class="wrap"><table>
        <thead><tr><th class="num">#</th><th>Symbol</th><th>Ergebnis %</th><th>Ergebnis $</th><th>Grund</th><th>Zeit</th></tr></thead>
        <tbody id="ptrades"></tbody>
      </table></div>
      <div class="empty" id="ptrades_e" style="display:none">Noch keine abgeschlossenen Trades.</div>
    </div>
  </div>
</section>

<!-- ─────────── SCREENING-WATCHLIST ─────────── -->
<section style="border-bottom:none">
  <h2>🔎 Screening-Watchlist <span style="color:var(--dim);font-weight:400;text-transform:none;letter-spacing:0">— sortiert nach Performance seit Entdeckung</span></h2>
  <div class="cards" id="scards"></div>
  <div class="wrap"><table>
    <thead><tr>
      <th>Symbol</th><th>Preis</th><th>seit Entdeckung</th><th>Mom. 1h</th>
      <th>5h-Vol</th><th>Liquidität</th><th>Buy/Sell</th><th>Rug</th><th title="Insider-Konzentration Top2-11 ohne LP; 🔒=Freeze-Authority=nicht verkaufbar">Holder</th><th title="Insider/Bundle-Wallets (RugCheck) — koordinierte Cluster = Dump-Gefahr; ⚠️=hoher RugCheck-Risiko-Score">Insider</th><th title="Holder-Zahl (Adoption) — sehr wenige = riskant/neu, viele = organisch verteilt">#Holder</th><th>Alter</th>
    </tr></thead>
    <tbody id="rows"></tbody>
  </table></div>
  <div class="empty" id="wl_e" style="display:none">Noch keine Token auf der Watchlist — Screening läuft…</div>
</section>

<script>
function fmtPrice(p){
  const n = parseFloat(p);
  if (!isFinite(n) || n === 0) return "–";
  if (n >= 1) return "$" + n.toLocaleString("de-DE",{maximumFractionDigits:4});
  return "$" + n.toPrecision(3);
}
function usd0(n){ return "$" + (Number(n)||0).toLocaleString("de-DE",{maximumFractionDigits:0}); }
function usd2(n){ return "$" + (Number(n)||0).toLocaleString("de-DE",{minimumFractionDigits:2,maximumFractionDigits:2}); }
function pct(n){ n=Number(n)||0; return (n>=0?"+":"")+n.toFixed(1)+"%"; }
async function getJSON(f){ try { return await (await fetch(f+"?_="+Date.now())).json(); } catch(e){ return null; } }

async function load(){
  const [ph, ps, pt, wl, hb, ph9, pt9, ph10, pt10, ph11, pt11, ph12, pt12] = await Promise.all([
    getJSON("paper_heartbeat.json"), getJSON("paper_state.json"),
    getJSON("paper_trades.json"), getJSON("watchlist.json"), getJSON("heartbeat.json"),
    getJSON("paper_heartbeat_v9.json"), getJSON("paper_trades_v9.json"),
    getJSON("paper_heartbeat_v10.json"), getJSON("paper_trades_v10.json"),
    getJSON("paper_heartbeat_v11.json"), getJSON("paper_trades_v11.json"),
    getJSON("paper_heartbeat_v12.json"), getJSON("paper_trades_v12.json")
  ]);

  // ── A/B: Baseline v7 vs v8 Aggro-Pyramid ──
  const vstat = (h,tr)=>{ tr=tr||[]; const e=h?h.equity:500, n=h?h.trades:0,
    net=tr.reduce((a,t)=>a+(t.profit||0),0);
    return {eq:e, ret:(e/500-1)*100, n, wr:(h&&h.trades)?(h.wins/h.trades*100):0, net, avg:n?net/n:0}; };
  const abrow = (nm,s)=>`<tr><td><b>${nm}</b></td>
    <td class="num ${s.ret>=0?'pos':'neg'}">${usd2(s.eq)}</td>
    <td class="num ${s.ret>=0?'pos':'neg'}">${pct(s.ret)}</td>
    <td class="num">${s.n}</td>
    <td class="num ${s.wr>=50?'pos':'dim'}">${s.wr.toFixed(0)}%</td>
    <td class="num ${s.net>=0?'pos':'neg'}">${usd0(s.net)}</td>
    <td class="num ${s.avg>=0?'pos':'neg'}">${usd2(s.avg)}</td></tr>`;
  document.getElementById("abrows").innerHTML =
    abrow("v7 Kontrolle", vstat(ph,pt)) + abrow("v9 Fade-Cut", vstat(ph9,pt9)) + abrow("v10 Vel300", vstat(ph10,pt10)) + abrow("v11 Vel+Fade", vstat(ph11,pt11)) + abrow("v12 Jupiter-Fill", vstat(ph12,pt12));

  // ── Paper KPIs ──
  const eq = ph ? ph.equity : 500, start = 500;
  const ret = (eq/start - 1)*100;
  const wr = (ph && ph.trades) ? (ph.wins/ph.trades*100) : 0;
  document.getElementById("pcards").innerHTML = `
    <div class="kpi"><div class="v ${ret>=0?'pos':'neg'}">${usd2(eq)}</div><div class="l">Equity (${pct(ret)})</div></div>
    <div class="kpi"><div class="v">${usd2(ph?ph.bankroll:start)}</div><div class="l">Bankroll frei</div></div>
    <div class="kpi"><div class="v">${ph?ph.open:0}</div><div class="l">offene Wetten</div></div>
    <div class="kpi"><div class="v">${ph?ph.trades:0}</div><div class="l">Trades</div></div>
    <div class="kpi"><div class="v ${wr>=50?'pos':'dim'}">${wr.toFixed(0)}%</div><div class="l">Win-Rate</div></div>`;

  // ── Open paper positions ──
  const pos = (ps && ps.positions) ? Object.values(ps.positions) : [];
  const ob = document.getElementById("popen"); ob.innerHTML = "";
  document.getElementById("popen_e").style.display = pos.length ? "none" : "block";
  pos.sort((a,b)=> ((b.last_price/b.entry)||0)-((a.last_price/a.entry)||0));
  pos.forEach((p, i) => {
    const pl = p.entry>0 ? (p.last_price/p.entry-1)*100 : 0;
    const plUsd = (p.shares||0)*(p.last_price||0) + (p.realized||0) - (p.bet||20);
    const fromPeak = p.peak>0 ? (p.last_price/p.peak-1)*100 : 0;
    const isPrem = p.premium === true;
    const st = isPrem
      ? (p.scaled ? '<span class="pill house">House-Money</span>' : '<span class="pill premium">🌟 Premium</span>')
      : (p.scaled ? '<span class="pill house">House-Money</span>' : '<span class="pill run">läuft</span>');
    ob.insertAdjacentHTML("beforeend", `<tr class="${isPrem?'premium-row':''}">
      <td class="num">${i+1}</td>
      <td class="sym">${p.symbol||"?"}</td>
      <td>${fmtPrice(p.entry)}</td>
      <td>${fmtPrice(p.last_price)}</td>
      <td class="${pl>=0?'pos':'neg'}">${pct(pl)}</td>
      <td class="${plUsd>=0?'pos':'neg'}">${plUsd>=0?'+':''}${usd2(plUsd)}</td>
      <td class="dim">${pct(fromPeak)}</td>
      <td>${st}</td></tr>`);
  });

  // ── Recent paper trades ──
  const trs = (pt||[]).slice(-15).reverse();
  const tb = document.getElementById("ptrades"); tb.innerHTML = "";
  document.getElementById("ptrades_e").style.display = trs.length ? "none" : "block";
  trs.forEach((t, i) => {
    const win = (t.profit||0) > 0;
    const tag = t.reason==="RUG-TOTAL" ? "💀" : (win ? "🚀" : "");
    const rc = t.reason==="RUG-TOTAL" ? "neg" : "dim";
    const profitStr = (t.profit>=0?'+':'') + usd2(t.profit);
    tb.insertAdjacentHTML("beforeend", `<tr>
      <td class="num">${trs.length - i}</td>
      <td class="sym">${t.symbol||"?"} ${tag}</td>
      <td class="${(t.pct||0)>=0?'pos':'neg'}">${pct(t.pct)}</td>
      <td class="${win?'pos':'neg'}">${profitStr}</td>
      <td class="${rc}">${t.reason||""}</td>
      <td class="dim">${(t.time||"").slice(5)}</td></tr>`);
  });

  // ── Watchlist ──
  const rows = Object.values(wl||{}).map(t => {
    const cur = parseFloat(t.price), first = parseFloat(t.first_price || t.price);
    const perf = (isFinite(cur)&&isFinite(first)&&first>0) ? (cur-first)/first*100 : 0;
    return {...t, perf};
  }).sort((a,b)=> b.perf - a.perf);
  const rb = document.getElementById("rows"); rb.innerHTML = "";
  document.getElementById("wl_e").style.display = rows.length ? "none" : "block";
  for (const t of rows){
    const bs = (t.sells>0 && t.buys/t.sells < 1) ? "neg" : "pos";
    const rugCls = (t.rug_risk && t.rug_risk!=="ok" && t.rug_risk!=="?") ? "warn" : "ok";
    const oc = t.onchain || {};
    const conc = (typeof oc.conc === "number") ? oc.conc : null;
    const hCls = oc.freeze ? "neg" : (conc!==null && conc>40 ? "neg" : (conc!==null && conc<=20 ? "pos" : "dim"));
    const hTxt = oc.freeze ? "🔒" : (conc!==null ? Math.round(conc)+"%" : "–");
    // Forensik Phase 1: Insider/Bundle-Cluster + Holder-Zahl + RugCheck-Risiko
    const ins = (typeof oc.insiders === "number") ? oc.insiders : null;
    const insCls = ins===null ? "dim" : (ins>=15 ? "neg" : (ins>=5 ? "amber" : "pos"));
    const insTxt = ins===null ? "–" : String(ins);
    const hold = (typeof oc.holders === "number") ? oc.holders : null;
    const holdCls = hold===null ? "dim" : (hold<30 ? "neg" : (hold>=500 ? "pos" : "dim"));
    const holdTxt = hold===null ? "–" : hold.toLocaleString("de-DE");
    const rc = (typeof oc.rc_score === "number") ? oc.rc_score : null;
    const rcWarn = (rc!==null && rc>=20) ? " ⚠️" : "";
    rb.insertAdjacentHTML("beforeend", `<tr>
      <td class="sym">${t.symbol||"?"}</td><td>${fmtPrice(t.price)}</td>
      <td class="${t.perf>=0?'pos':'neg'}">${pct(t.perf)}</td>
      <td class="${(t.chg1||0)>=0?'pos':'neg'}">${pct(t.chg1||t.chg5||0)}</td>
      <td class="dim">${usd0(t.vol_h6)}</td><td>${usd0(t.liq)}</td>
      <td class="${bs}">${t.buys}/${t.sells}</td>
      <td><span class="pill ${rugCls}">${t.rug_risk||"?"}</span></td>
      <td class="${hCls}" title="Insider-Konzentration Top2-11 (ohne LP) — 🔒 = Freeze-Authority = nicht verkaufbar">${hTxt}</td>
      <td class="${insCls}" title="Insider/Bundle-Wallets${oc.insider_nets?' · '+oc.insider_nets+' Netze':''}">${insTxt}</td>
      <td class="${holdCls}" title="Holder-Zahl (Adoption)${rc!==null?' · RugCheck-Score '+rc:''}">${holdTxt}${rcWarn}</td>
      <td class="dim">${t.age_h}h</td></tr>`);
  }
  document.getElementById("scards").innerHTML = `
    <div class="kpi"><div class="v">${hb?hb.screened:0}</div><div class="l">gescreent / Zyklus</div></div>
    <div class="kpi"><div class="v pos">${hb?hb.passed:0}</div><div class="l">bestanden</div></div>
    <div class="kpi"><div class="v">${rows.length}</div><div class="l">Watchlist</div></div>`;

  const pa = ph && ph.ts ? Math.round((Date.now()/1000-ph.ts)/60) : "?";
  document.getElementById("updated").textContent =
    "Paper-Zyklus " + (ph?ph.cycle:"?") + " · Update vor " + pa + " min · Refresh 15s";
}
load();
setInterval(load, 15000);
</script>
</body>
</html>
