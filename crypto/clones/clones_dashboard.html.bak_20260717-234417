<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Clone-Experiment — A/B/C/D</title>
<style>
  :root { --bg:#0e1116; --card:#171c24; --line:#262d38; --txt:#e6edf3; --dim:#8b949e;
          --green:#3fb950; --red:#f85149; --gold:#d4a017; --blue:#58a6ff; }
  * { box-sizing:border-box; }
  body { margin:0; background:var(--bg); color:var(--txt);
         font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif; }
  header { padding:18px 22px; border-bottom:1px solid var(--line);
           display:flex; align-items:baseline; gap:16px; flex-wrap:wrap; }
  h1 { font-size:20px; margin:0; }
  .sub { color:var(--dim); font-size:13px; }
  #updated { margin-left:auto; color:var(--dim); font-size:12px; }
  .grid { display:grid; grid-template-columns:repeat(3,1fr);
          gap:16px; padding:22px; }
  @media (max-width:1100px){ .grid{ grid-template-columns:repeat(2,1fr); } }
  @media (max-width:680px){  .grid{ grid-template-columns:1fr; } }
  .card { background:var(--card); border:1px solid var(--line); border-radius:12px;
          padding:18px; position:relative; }
  .card.leader { border-color:var(--gold); box-shadow:0 0 0 1px var(--gold) inset; }
  .rank { position:absolute; top:14px; right:16px; font-size:12px; color:var(--dim); }
  .leader .rank { color:var(--gold); font-weight:600; }
  .vname { font-size:16px; font-weight:600; margin:0 0 2px; }
  .vdesc { color:var(--dim); font-size:12px; margin-bottom:14px; }
  .equity { font-size:30px; font-weight:700; letter-spacing:-.5px; }
  .ret { font-size:16px; font-weight:600; margin-left:6px; }
  .pos { color:var(--green); } .neg { color:var(--red); }
  .row { display:flex; justify-content:space-between; font-size:13px;
         padding:5px 0; border-top:1px solid var(--line); }
  .row .k { color:var(--dim); }
  .holdings { margin-top:12px; }
  .htitle { font-size:11px; color:var(--dim); text-transform:uppercase;
            letter-spacing:.5px; margin-bottom:6px; }
  .hitem { display:flex; justify-content:space-between; font-size:12px; padding:2px 0;
           font-variant-numeric:tabular-nums; }
  .hsym { color:var(--blue); }
  .dimusd { color:var(--dim); font-size:11px; }
  .titem { display:flex; justify-content:space-between; gap:6px; font-size:11.5px; padding:2px 0;
           font-variant-numeric:tabular-nums; align-items:baseline; }
  .titem .tsym { color:var(--blue); flex:1 1 auto; overflow:hidden; text-overflow:ellipsis;
                 white-space:nowrap; }
  .titem .tr { color:var(--dim); font-size:10px; min-width:64px; text-align:right; }
  .stale { color:var(--red); font-size:11px; }
  .empty { color:var(--dim); font-size:12px; font-style:italic; }
</style>
</head>
<body>
<header>
  <h1>🧬 Clone-Experiment</h1>
  <span class="sub">5 Strategien · identische Gateway-Daten · je $5.000 Start</span>
  <span id="updated">lädt…</span>
</header>
<div class="grid" id="grid"></div>

<script>
const META = {
  "A_baseline":          { label:"A · Baseline",        desc:"Momentum + Spikes + Memes (Kontrolle: handelt alles)" },
  "F_contrarian_vix28":  { label:"F · Deep-Fear 😱",   desc:"RSI<20 + Supertrend bull + F&G<25 (Extreme Fear)" },
  "G_core":              { label:"G · Mid-Cap Core 🎯", desc:"Momentum ohne Spikes/Memes/BTC/ETH" },
  "H_contra_refined":    { label:"H · Refined Contra ↩", desc:"Contrarian + Supertrend-Bestätigung (kein Messerfangen)" },
  "G_big":               { label:"G_big · MEXC-Szenario 💰", desc:"G_core-Strategie, 2× Einsatz (pos 12%/Risiko 2%) + MEXC-Fee 0,05% (vs Kraken 0,26%)" },
};
const START = 5000;
const order = ["A_baseline","F_contrarian_vix28","G_core","H_contra_refined","G_big"];

function equityOf(d){
  let eq = d.balance || 0;
  const p = d.positions || {};
  for (const s in p){ eq += (p[s].shares||0) * (p[s].current_price|| p[s].entry ||0); }
  return eq;
}
function winRate(trades){
  if(!trades || !trades.length) return null;
  const w = trades.filter(t => (t.profit||0) > 0).length;
  return Math.round(w / trades.length * 100);
}
function avgWL(trades){
  if(!trades || !trades.length) return null;
  const w = trades.filter(t=>(t.profit||0)>0).map(t=>t.profit);
  const l = trades.filter(t=>(t.profit||0)<=0).map(t=>t.profit);
  const avg = a => a.length ? a.reduce((x,y)=>x+y,0)/a.length : 0;
  return { w:avg(w), l:avg(l), net:trades.reduce((x,t)=>x+(t.profit||0),0) };
}
function fmt(n){ return "$" + (n).toLocaleString("de-DE",{maximumFractionDigits:0}); }

async function load(){
  const cards = [];
  for (const v of order){
    try {
      const r = await fetch(v + "_dashboard.json?_=" + Date.now());
      const d = await r.json();
      const eq = equityOf(d);
      const ret = (eq - START) / START * 100;
      const ageMin = d.time ? (Date.now() - new Date(d.time.replace(" ","T")).getTime())/60000 : 999;
      cards.push({ v, d, eq, ret, age:ageMin });
    } catch(e){
      cards.push({ v, d:null, eq:0, ret:-9999, age:999 });
    }
  }
  // rank by return desc (only those with data)
  const ranked = [...cards].sort((a,b)=> b.ret - a.ret);
  const leaderV = ranked[0] && ranked[0].d ? ranked[0].v : null;

  const grid = document.getElementById("grid");
  grid.innerHTML = "";
  for (const c of cards){
    const m = META[c.v];
    const el = document.createElement("div");
    el.className = "card" + (c.v===leaderV ? " leader" : "");
    if (!c.d){
      el.innerHTML = `<div class="vname">${m.label}</div>
        <div class="vdesc">${m.desc}</div><div class="stale">⚠ keine Daten / Clone offline</div>`;
      grid.appendChild(el); continue;
    }
    const rankIdx = ranked.findIndex(x=>x.v===c.v)+1;
    const pos = c.d.positions || {};
    const posKeys = Object.keys(pos);
    const wr = winRate(c.d.trades);
    const awl = avgWL(c.d.trades);
    // Offene Positionen — jetzt mit P&L in $
    let holdings = `<div class="empty">keine offenen Positionen</div>`;
    if (posKeys.length){
      holdings = posKeys.map(s=>{
        const pl = pos[s].pnl_pct||0, usd = pos[s].pnl_usd||0;
        const cls = pl>=0 ? "pos":"neg";
        const tag = pos[s].spike ? " ⚡" : (pos[s].contrarian ? " ↩" : "");
        return `<div class="hitem"><span class="hsym">${s}${tag}</span>
                <span class="${cls}">${pl>=0?"+":""}${pl.toFixed(1)}% <span class="dimusd">(${usd>=0?"+":""}$${Math.round(usd)})</span></span></div>`;
      }).join("");
    }
    // Letzte Trades (neueste zuerst) — Symbol, %, $, Grund; Zeit als Tooltip
    const rtr = (c.d.trades||[]).slice(-8).reverse();
    let tradeHtml = `<div class="empty">noch keine Trades</div>`;
    if (rtr.length){
      tradeHtml = rtr.map(t=>{
        const pl=t.pct||0, usd=t.profit||0, cls=usd>=0?"pos":"neg";
        const rs=(t.reason||"").replace("WS-","");
        return `<div class="titem" title="${t.time||""}">
          <span class="tsym">${t.symbol}${t.spike?" ⚡":""}</span>
          <span class="${cls}">${pl>=0?"+":""}${pl.toFixed(1)}%</span>
          <span class="${cls}">${usd>=0?"+":""}$${Math.round(usd)}</span>
          <span class="tr">${rs}</span></div>`;
      }).join("");
    }
    const retCls = c.ret>=0 ? "pos":"neg";
    const awlStr = awl ? `<span class="pos">+$${awl.w.toFixed(1)}</span> / <span class="neg">$${awl.l.toFixed(1)}</span>` : "–";
    const netStr = awl ? `<span class="${awl.net>=0?'pos':'neg'}">${awl.net>=0?"+":""}$${Math.round(awl.net)}</span>` : "–";
    el.innerHTML = `
      <div class="rank">#${rankIdx}${c.v===leaderV?" 👑":""}</div>
      <div class="vname">${m.label}</div>
      <div class="vdesc">${m.desc}</div>
      <div><span class="equity">${fmt(c.eq)}</span>
           <span class="ret ${retCls}">${c.ret>=0?"+":""}${c.ret.toFixed(2)}%</span></div>
      ${c.age>10 ? `<div class="stale">⚠ Daten ${Math.round(c.age)} min alt</div>`:""}
      <div class="row"><span class="k">Cash</span><span>${fmt(c.d.balance||0)}</span></div>
      <div class="row"><span class="k">Offene Positionen</span><span>${posKeys.length}/8</span></div>
      <div class="row"><span class="k">Trades gesamt · Win-Rate</span><span>${c.d.total_trades||0} · ${wr===null?"–":wr+"%"}</span></div>
      <div class="row"><span class="k">Ø Gewinn / Verlust</span><span>${awlStr}</span></div>
      <div class="row"><span class="k">Netto realisiert</span><span>${netStr}</span></div>
      <div class="holdings"><div class="htitle">Offene Positionen</div>${holdings}</div>
      <div class="holdings"><div class="htitle">Letzte Trades</div>${tradeHtml}</div>`;
    grid.appendChild(el);
  }
  const fg = cards.find(c=>c.d && c.d.fear_greed);
  const fgStr = fg ? ` · F&G ${fg.d.fear_greed.value} ${fg.d.fear_greed.label}` : "";
  document.getElementById("updated").textContent =
    "Stand " + new Date().toLocaleTimeString("de-DE") + fgStr + " · Auto-Refresh 15s";
}
load();
setInterval(load, 15000);
</script>
</body>
</html>
